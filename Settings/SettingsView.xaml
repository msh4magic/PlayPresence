<UserControl x:Class="PlayPresence.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignWidth="820"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Thickness x:Key="RowMargin">0,6,0,6</Thickness>
        <Thickness x:Key="SectionMargin">0,4,0,18</Thickness>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,10" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,3" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="CheckRow" TargetType="CheckBox">
            <Setter Property="Margin" Value="{StaticResource RowMargin}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="10" TextElement.Foreground="{DynamicResource TextBrush}" TextBlock.Foreground="{DynamicResource TextBrush}">

        <!-- ===================== Getting started (first run) ===================== -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,10" Padding="14" CornerRadius="8"
                Background="{DynamicResource PopupBackgroundBrush}"
                Visibility="{Binding ShowGettingStarted, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource LOCPlayPresence_FirstRunTitle}" />
                <TextBlock Style="{StaticResource Hint}" Text="{DynamicResource LOCPlayPresence_FirstRunIntro}" />

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"
                               Foreground="{DynamicResource TextBrush}"
                               Text="{Binding StepDiscordText}" />
                    <Button Grid.Row="0" Grid.Column="1" Margin="8,2" Padding="10,4"
                            Content="{DynamicResource LOCPlayPresence_OpenDiscordPortal}"
                            Command="{Binding OpenDiscordPortalCommand}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"
                               Foreground="{DynamicResource TextBrush}"
                               Text="{Binding StepIgdbText}" />
                    <Button Grid.Row="1" Grid.Column="1" Margin="8,2" Padding="10,4"
                            Content="{DynamicResource LOCPlayPresence_OpenIgdbPortal}"
                            Command="{Binding OpenIgdbPortalCommand}" />
                </Grid>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- ===================== Tabs ===================== -->
            <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0">

                <TabItem Header="{DynamicResource LOCPlayPresence_TabGeneral}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource LOCPlayPresence_GeneralHeader}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_EnableRichPresence}" IsChecked="{Binding Settings.EnableRichPresence}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_ShowDesktop}" IsChecked="{Binding Settings.ShowInDesktopMode}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_ShowFullscreen}" IsChecked="{Binding Settings.ShowInFullscreenMode}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_ShowSourceContext}" IsChecked="{Binding Settings.ShowSourceContext}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_ShowTimer}" IsChecked="{Binding Settings.ShowElapsedTimer}" />
                            <Separator Margin="{StaticResource SectionMargin}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_EnableIdle}" IsChecked="{Binding Settings.EnableIdlePresence}" />
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource LOCPlayPresence_IdleText}" />
                            <TextBox Text="{Binding Settings.IdlePresenceText}" Margin="{StaticResource RowMargin}" />
                            <Separator Margin="{StaticResource SectionMargin}" />
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource LOCPlayPresence_PrivacyHeader}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_PrivateMode}" IsChecked="{Binding Settings.PrivateMode}" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{DynamicResource LOCPlayPresence_TabDiagnostics}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource LOCPlayPresence_ActionsHeader}" />
                            <WrapPanel>
                                <Button Content="{DynamicResource LOCPlayPresence_TestConnection}" Command="{Binding TestConnectionCommand}" Margin="0,0,8,8" Padding="14,6" />
                                <Button Content="{DynamicResource LOCPlayPresence_Reconnect}" Command="{Binding ReconnectCommand}" Margin="0,0,8,8" Padding="14,6" />
                                <Button Content="{DynamicResource LOCPlayPresence_ClearCache}" Command="{Binding ClearCacheCommand}" Margin="0,0,8,8" Padding="14,6" />
                            </WrapPanel>
                            <WrapPanel>
                                <Button Content="{DynamicResource LOCPlayPresence_ResetDefaults}" Command="{Binding ResetDefaultsCommand}" Margin="0,0,8,8" Padding="14,6" />
                            </WrapPanel>
                            <Border Margin="0,6,0,14" Padding="10" CornerRadius="6" Background="{DynamicResource PopupBackgroundBrush}">
                                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" MinHeight="20" />
                            </Border>
                            <Separator Margin="{StaticResource SectionMargin}" />
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource LOCPlayPresence_LoggingHeader}" />
                            <CheckBox Style="{StaticResource CheckRow}" Content="{DynamicResource LOCPlayPresence_EnableDebug}" IsChecked="{Binding Settings.EnableDebugLogging}" />
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource LOCPlayPresence_LogVerbosity}" />
                            <ComboBox Margin="{StaticResource RowMargin}" Width="220" HorizontalAlignment="Left" ItemsSource="{Binding LogVerbosityOptions}" SelectedItem="{Binding Settings.LogVerbosity}" />

                            <Separator Margin="{StaticResource SectionMargin}" />
                            <StackPanel Orientation="Vertical" Margin="0,4,0,0" HorizontalAlignment="Left">
                                <TextBlock Text="{DynamicResource LOCPlayPresence_About}"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />
                                <Button Content="{DynamicResource LOCPlayPresence_SupportKofi}"
                                        Command="{Binding OpenKofiCommand}" Padding="14,6" HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

        </Grid>
    </DockPanel>
</UserControl>
